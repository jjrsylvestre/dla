<exercisegroup cols="2">
	<title>Systems as matrix equations</title>

	<introduction><p> Express each system of equations as a single matrix equation <m>A \uvec{x} = \uvec{b}</m>. </p></introduction>

	<exercise>
		<statement><p><m>\displaystyle
			\begin{sysofeqns}{rcrcr}
				6 x \amp + \amp 9 y \amp = \amp -2 \\
				4 x \amp - \amp 5 y \amp = \amp  4
			\end{sysofeqns}
		</m></p></statement>
		<answer><p><m>\displaystyle
			\left[\begin{array}{rr}
				6 \amp  9 \\
				4 \amp -5
			\end{array}\right]
			\begin{bmatrix} x \\ y \end{bmatrix}
			=
			\left[\begin{array}{r} -2 \\ 4 \end{array}\right]
		</m></p></answer>
	</exercise>

	<exercise>
		<statement><p><m>\displaystyle
			\begin{sysofeqns}{rcrcr}
				2 x \amp - \amp   y \amp = \amp  0 \\
				8 x \amp - \amp 2 y \amp = \amp -1 \\
				4 x \amp - \amp 8 y \amp = \amp  0
			\end{sysofeqns}
		</m></p></statement>
		<answer><p><m>\displaystyle
			\left[\begin{array}{rr}
				2 \amp -1 \\
				8 \amp -2 \\
				4 \amp -8
			\end{array}\right]
			\begin{bmatrix} x \\ y \end{bmatrix}
			=
			\left[\begin{array}{r} 0 \\ -1 \\ 0 \end{array}\right]
		</m></p></answer>
	</exercise>

	<exercise>
		<statement><p><m>\displaystyle
			\begin{sysofeqns}{rcrcrcr}
				 8 x \amp - \amp   y \amp + \amp 3 z \amp = \amp -6 \\
				 4 x \amp + \amp 9 y \amp + \amp 7 z \amp = \amp -8 \\
				-1 x \amp + \amp   y \amp - \amp 5 z \amp = \amp  5
			\end{sysofeqns}
		</m></p></statement>
		<answer><p><m>\displaystyle
			\left[\begin{array}{rrr}
				 8 \amp -1 \amp  3 \\
				 4 \amp  9 \amp  7 \\
				-1 \amp  1 \amp -5
			\end{array}\right]
			\begin{bmatrix} x \\ y \\ z \end{bmatrix}
			=
			\left[\begin{array}{r} -6 \\ -8 \\ 5 \end{array}\right]
		</m></p></answer>
	</exercise>

	<exercise>
		<statement><p><m>\displaystyle
			\begin{sysofeqns}{rcrcrcrcr}
				 5 x_1 \amp   \amp       \amp + \amp 9 x_3 \amp + \amp   x_4 \amp = \amp 7 \\
				-2 x_1 \amp + \amp 8 x_2 \amp + \amp   x_3 \amp - \amp 7 x_4 \amp = \amp 9
			\end{sysofeqns}
		</m></p></statement>
		<answer><p><m>\displaystyle
			\left[\begin{array}{rrrr}
				 5 \amp 0 \amp 9 \amp  1 \\
				-2 \amp 8 \amp 1 \amp -7
			\end{array}\right]
			\begin{bmatrix} x_1 \\ x_2 \\ x_3 \\ x_4 \end{bmatrix}
			=
			\begin{bmatrix} 7 \\ 9 \end{bmatrix}
		</m></p></answer>
	</exercise>

</exercisegroup>
