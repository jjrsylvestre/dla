<exercisegroup cols="2">
	<title>Expressing systems using matrix multiplication</title>

	<introduction><p> Express each system as a matrix equation <m>A \uvec{x} = \uvec{b}</m>. </p></introduction>

	<exercise>
		<statement><p><m>\displaystyle
			\begin{sysofeqns}{rcrcr}
				6 x \amp + \amp 9 y \amp = \amp -2 \\
				4 x \amp - \amp 5 y \amp = \amp  4
			\end{sysofeqns}
		</m></p></statement>
		<answer><p><m>\displaystyle
			\left[\begin{array}{rr}
				6 \amp  9 \\
				4 \amp -5
			\end{array}\right]
			\begin{bmatrix} x \\ y \end{bmatrix}
			=
			\left[\begin{array}{r} -2 \\ 4 \end{array}\right]
		</m></p></answer>
	</exercise>

	<exercise><p>TODO MORE</p></exercise>

</exercisegroup>
